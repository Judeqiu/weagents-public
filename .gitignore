# ============================================
# Security - Never commit files with secrets!
# ============================================

# Environment files (contain API keys, tokens, passwords)
.env
.env.local
.env.*.local
**/.env
!**/.env.example

# Skill config files (contain API keys)
skills/**/config.json
!skills/**/config.json.example

# Secrets and credentials
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Node modules and virtual environments
node_modules/
.venv/
venv/
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Backup files
*.bak
*.backup
